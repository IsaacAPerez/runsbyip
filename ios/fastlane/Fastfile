default_platform(:ios)

NOTIFY_SCRIPT = File.expand_path("../scripts/notify_ci.sh", __dir__)

after_all do |lane|
  sh("#{NOTIFY_SCRIPT} #{lane} success || true")
end

error do |lane, exception|
  sh("#{NOTIFY_SCRIPT} #{lane} failure '#{exception.message.gsub("'", "")}' || true")
end

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "RunsByIP.xcodeproj"
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"] || "RRYR26DJLS",
      issuer_id: ENV["ASC_ISSUER_ID"] || "d0ded18b-a760-49f9-82b3-135bb3b65703",
      key_filepath: ENV["ASC_KEY_PATH"] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_RRYR26DJLS.p8"),
      duration: 1200,
      in_house: false
    )

    build_app(
      scheme: "RunsByIP",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates -allowProvisioningDeviceRegistration",
      export_options: {
        method: "app-store",
        teamID: "K98N9692X9",
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )

    puts "✅ Uploaded to TestFlight!"
  end

end
