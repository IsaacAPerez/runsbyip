default_platform(:ios)

NOTIFY_SCRIPT = File.expand_path("../scripts/notify_ci.sh", __dir__)
PROJECT_DIR = File.expand_path("..", __dir__)
PROJECT_YML = "#{PROJECT_DIR}/project.yml"
APP_IDENTIFIER = "com.isaacperez.runsbyip"
ASC_APP_ID = "6761027495"
API_KEY_ID = "RRYR26DJLS"
API_ISSUER_ID = "d0ded18b-a760-49f9-82b3-135bb3b65703"

# Compact ASC API client — just enough to predict whether a marketing
# version's TestFlight train is still accepting uploads. Mirrors the
# `train_open?` helper from CurbSide / RoommateApp Fastfiles.
class AscClient
  require 'jwt'
  require 'net/http'
  require 'json'
  require 'uri'

  BASE = "https://api.appstoreconnect.apple.com".freeze

  def initialize(key_id:, issuer_id:, key_path:)
    @key_id = key_id
    @issuer_id = issuer_id
    @private_key = OpenSSL::PKey::EC.new(File.read(key_path))
  end

  def token
    now = Time.now.to_i
    JWT.encode(
      { iss: @issuer_id, iat: now, exp: now + 1200, aud: "appstoreconnect-v1" },
      @private_key,
      "ES256",
      { kid: @key_id, typ: "JWT" }
    )
  end

  def request(method, path, body = nil)
    uri = URI("#{BASE}#{path}")
    req = case method
    when :get    then Net::HTTP::Get.new(uri)
    when :post   then Net::HTTP::Post.new(uri)
    when :patch  then Net::HTTP::Patch.new(uri)
    when :delete then Net::HTTP::Delete.new(uri)
    end
    req["Authorization"] = "Bearer #{token}"
    req["Content-Type"] = "application/json"
    req.body = body.to_json if body
    resp = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
    [resp.code.to_i, resp.body.to_s]
  end

  TRAIN_OPEN_STATES = %w[
    PREPARE_FOR_SUBMISSION
    DEVELOPER_REJECTED
    REJECTED
    METADATA_REJECTED
    INVALID_BINARY
  ].freeze

  # Returns true when version_string either has no appStoreVersion yet
  # (a brand-new train) or is in an editable state. Returns false only
  # when we're confident the train is closed — failures default to true
  # so we never refuse to ship over a flaky API call.
  def train_open?(app_id:, version_string:, platform: "IOS")
    code, body = request(
      :get,
      "/v1/apps/#{app_id}/appStoreVersions" \
      "?filter[platform]=#{platform}" \
      "&filter[versionString]=#{version_string}&limit=1"
    )
    return true unless code == 200
    data = JSON.parse(body)
    v = (data["data"] || []).first
    return true unless v
    state = v.dig("attributes", "appStoreState").to_s
    TRAIN_OPEN_STATES.include?(state)
  end

  # Look up the editable App Store Version (if any) for a given marketing
  # version. Returns { id:, state:, build_id: } or nil.
  def fetch_editable_version(app_id:, version_string:, platform: "IOS")
    code, body = request(
      :get,
      "/v1/apps/#{app_id}/appStoreVersions" \
      "?filter[platform]=#{platform}" \
      "&filter[versionString]=#{version_string}" \
      "&include=build&limit=5"
    )
    return nil unless code == 200
    data = JSON.parse(body)
    v = (data["data"] || []).first
    return nil unless v
    build_id = v.dig("relationships", "build", "data", "id")
    { id: v["id"], state: v["attributes"]["appStoreState"], build_id: build_id }
  end

  # Create an editable appStoreVersion for the given marketing version.
  def create_app_store_version(app_id:, version_string:, platform: "IOS", release_type: "MANUAL")
    code, body = request(:post, "/v1/appStoreVersions", {
      data: {
        type: "appStoreVersions",
        attributes: { platform: platform, versionString: version_string, releaseType: release_type },
        relationships: { app: { data: { type: "apps", id: app_id } } }
      }
    })
    raise "Failed to create appStoreVersion #{version_string} (#{code}): #{body}" unless code == 201
    JSON.parse(body).dig("data", "id")
  end

  # Find the latest VALID TestFlight build for a marketing version.
  def latest_valid_build(app_id:, version_string:)
    code, body = request(
      :get,
      "/v1/builds" \
      "?filter[app]=#{app_id}" \
      "&filter[preReleaseVersion.version]=#{version_string}" \
      "&filter[processingState]=VALID" \
      "&sort=-uploadedDate&limit=1"
    )
    return nil unless code == 200
    JSON.parse(body).dig("data", 0, "id")
  end

  # Attach a build to an appStoreVersion via the relationships endpoint.
  def attach_build(version_id:, build_id:)
    code, body = request(
      :patch,
      "/v1/appStoreVersions/#{version_id}/relationships/build",
      { data: { type: "builds", id: build_id } }
    )
    raise "Failed to attach build #{build_id} to version #{version_id} (#{code}): #{body}" unless code == 204
  end

  # PATCH the en-US localization's whatsNew field. Required for first-time
  # submission of a new version; Apple's reviewSubmissions endpoint rejects
  # versions with missing required localized attributes.
  def set_release_notes(version_id:, text:, locale: "en-US")
    code, body = request(:get, "/v1/appStoreVersions/#{version_id}/appStoreVersionLocalizations")
    raise "Failed to fetch localizations for version #{version_id} (#{code}): #{body}" unless code == 200
    loc = (JSON.parse(body)["data"] || []).find { |l| l.dig("attributes", "locale") == locale }
    raise "No #{locale} localization for version #{version_id}" unless loc
    code, body = request(:patch, "/v1/appStoreVersionLocalizations/#{loc['id']}", {
      data: {
        type: "appStoreVersionLocalizations",
        id: loc['id'],
        attributes: { whatsNew: text }
      }
    })
    raise "Failed to set whatsNew on localization #{loc['id']} (#{code}): #{body}" unless code == 200
  end

  # Submit via the modern reviewSubmissions flow (the legacy
  # appStoreVersionSubmissions endpoint only accepts DELETE since 2024).
  def submit_for_review(app_id:, platform: "IOS", version_id:)
    code, body = request(:post, "/v1/reviewSubmissions", {
      data: {
        type: "reviewSubmissions",
        attributes: { platform: platform },
        relationships: { app: { data: { type: "apps", id: app_id } } }
      }
    })
    raise "Failed to create reviewSubmission (#{code}): #{body}" unless code == 201
    submission_id = JSON.parse(body).dig("data", "id")

    code, body = request(:post, "/v1/reviewSubmissionItems", {
      data: {
        type: "reviewSubmissionItems",
        relationships: {
          reviewSubmission: { data: { type: "reviewSubmissions", id: submission_id } },
          appStoreVersion:  { data: { type: "appStoreVersions",  id: version_id } }
        }
      }
    })
    raise "Failed to add reviewSubmissionItem (#{code}): #{body}" unless code == 201

    code, body = request(:patch, "/v1/reviewSubmissions/#{submission_id}", {
      data: {
        type: "reviewSubmissions",
        id: submission_id,
        attributes: { submitted: true }
      }
    })
    raise "Failed to submit reviewSubmission (#{code}): #{body}" unless code == 200

    submission_id
  end
end

def asc_client(api_key_path)
  AscClient.new(key_id: API_KEY_ID, issuer_id: API_ISSUER_ID, key_path: api_key_path)
end

def current_marketing_version_from_yml
  m = File.read(PROJECT_YML).match(/^\s*MARKETING_VERSION:\s*"([^"]+)"/)
  raise "MARKETING_VERSION not found in #{PROJECT_YML}" unless m
  m[1]
end

def bump_patch_version(version)
  parts = version.split(".").map(&:to_i)
  parts << 0 while parts.size < 3
  parts[2] += 1
  parts.join(".")
end

# Bumps both `MARKETING_VERSION:` and `CFBundleShortVersionString:` in
# project.yml so xcodegen-regenerated pbxproj + Info.plist are consistent.
def bump_marketing_in_project_yml(new_version)
  content = File.read(PROJECT_YML)
  content = content.sub(/^(\s*MARKETING_VERSION:\s*")[^"]*(")/, "\\1#{new_version}\\2")
  content = content.sub(/^(\s+CFBundleShortVersionString:\s*")[^"]*(")/, "\\1#{new_version}\\2")
  File.write(PROJECT_YML, content)
end

after_all do |lane|
  sh("#{NOTIFY_SCRIPT} #{lane} success || true")
end

error do |lane, exception|
  sh("#{NOTIFY_SCRIPT} #{lane} failure '#{exception.message.gsub("'", "")}' || true")
end

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    # ASC_KEY_PATH must be set by CI (or the developer) — typically the
    # workflow's "Materialize ASC API key from 1Password" step writes the
    # .p8 to $RUNNER_TEMP and exports the path. No on-disk fallback: every
    # build pulls fresh from 1P, then the temp file is auto-cleaned at job end.
    asc_key_path = ENV.fetch("ASC_KEY_PATH") { raise "ASC_KEY_PATH not set — did the 'Materialize ASC API key' step run?" }
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"] || API_KEY_ID,
      issuer_id: ENV["ASC_ISSUER_ID"] || API_ISSUER_ID,
      key_filepath: asc_key_path,
      duration: 1200,
      in_house: false
    )

    # Auto-bump marketing version if the current train is closed in ASC.
    # Persisted: project.yml is rewritten, xcodegen re-runs, and the CI
    # workflow's "Commit bumped marketing version" step pushes the change
    # back to main. Failures default to "train open" so a flaky API call
    # never blocks a build.
    marketing_bumped_to = nil
    target_version = current_marketing_version_from_yml
    unless asc_client(asc_key_path).train_open?(app_id: ASC_APP_ID, version_string: target_version)
      bumped = bump_patch_version(target_version)
      UI.important("Train #{target_version} is closed in ASC; bumping to #{bumped}.")
      bump_marketing_in_project_yml(bumped)
      sh("cd #{PROJECT_DIR} && xcodegen generate")
      marketing_bumped_to = bumped
    end

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "RunsByIP.xcodeproj"
    )

    match(
      type: "appstore",
      app_identifier: "com.isaacperez.runsbyip",
      readonly: !ENV["MATCH_FORCE"],
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "RunsByIP.xcodeproj",
      team_id: "K98N9692X9",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.isaacperez.runsbyip",
      profile_name: "match AppStore com.isaacperez.runsbyip",
      build_configurations: ["Release"],
      targets: ["RunsByIP"]
    )

    build_app(
      scheme: "RunsByIP",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "K98N9692X9",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.isaacperez.runsbyip" => "match AppStore com.isaacperez.runsbyip"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )

    if marketing_bumped_to && ENV["GITHUB_ENV"]
      File.open(ENV["GITHUB_ENV"], "a") { |f| f.puts "MARKETING_BUMPED=#{marketing_bumped_to}" }
    end

    puts "✅ Uploaded to TestFlight!"
  end

  desc "Submit the latest TestFlight build for App Store review (no metadata sync — assumes ASC has current metadata + screenshots)"
  lane :submit do
    asc_key_path = ENV.fetch("ASC_KEY_PATH") { raise "ASC_KEY_PATH not set" }
    api_key = app_store_connect_api_key(
      key_id: API_KEY_ID,
      issuer_id: API_ISSUER_ID,
      key_filepath: asc_key_path
    )
    client = asc_client(asc_key_path)
    version = current_marketing_version_from_yml

    info = client.fetch_editable_version(app_id: ASC_APP_ID, version_string: version)
    if info.nil?
      UI.message("No App Store version for #{version} — creating draft (releaseType=MANUAL)…")
      version_id = client.create_app_store_version(app_id: ASC_APP_ID, version_string: version)
      info = { id: version_id, state: "PREPARE_FOR_SUBMISSION", build_id: nil }
    end
    if info[:build_id].nil?
      build_id = client.latest_valid_build(app_id: ASC_APP_ID, version_string: version)
      if build_id.nil?
        UI.message("No VALID TestFlight build yet for #{version} — waiting for Apple to finish processing (up to 30 min)…")
        wait_for_build_processing(
          api_key: api_key,
          app_identifier: APP_IDENTIFIER,
          timeout_duration: 1800
        )
        build_id = client.latest_valid_build(app_id: ASC_APP_ID, version_string: version)
        UI.user_error!("Build never reached VALID state for #{version}. Run `fastlane beta` first or check ASC for processing errors.") if build_id.nil?
      end
      UI.message("Attaching build #{build_id} to version #{info[:id]}…")
      client.attach_build(version_id: info[:id], build_id: build_id)
    end

    # Push release notes (whatsNew) to the en-US localization so Apple's
    # reviewSubmissions endpoint doesn't reject for missing required fields.
    notes_path = File.expand_path("metadata/en-US/release_notes.txt", __dir__)
    release_notes = File.exist?(notes_path) ? File.read(notes_path).strip : ""
    release_notes = "Bug fixes and improvements." if release_notes.empty?
    UI.message("Setting release notes (#{release_notes.length} chars)…")
    client.set_release_notes(version_id: info[:id], text: release_notes)

    submission_id = client.submit_for_review(app_id: ASC_APP_ID, version_id: info[:id])
    UI.success("Submitted for review. reviewSubmission id: #{submission_id}")
  end

  desc "Sync signing certs and profiles from the shared certs repo (read-only)"
  lane :sync_signing do
    match(type: "appstore", app_identifier: "com.isaacperez.runsbyip", readonly: true)
  end

  desc "Generate or rotate signing certs and profiles in the shared certs repo"
  lane :rotate_signing do
    match(type: "appstore", app_identifier: "com.isaacperez.runsbyip", readonly: false)
  end

end
