default_platform(:ios)

NOTIFY_SCRIPT = File.expand_path("../scripts/notify_ci.sh", __dir__)

after_all do |lane|
  sh("#{NOTIFY_SCRIPT} #{lane} success || true")
end

error do |lane, exception|
  sh("#{NOTIFY_SCRIPT} #{lane} failure '#{exception.message.gsub("'", "")}' || true")
end

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "RunsByIP.xcodeproj"
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"] || "RRYR26DJLS",
      issuer_id: ENV["ASC_ISSUER_ID"] || "d0ded18b-a760-49f9-82b3-135bb3b65703",
      key_filepath: ENV["ASC_KEY_PATH"] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_RRYR26DJLS.p8"),
      duration: 1200,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: "com.isaacperez.runsbyip",
      readonly: !ENV["MATCH_FORCE"],
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "RunsByIP.xcodeproj",
      team_id: "K98N9692X9",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.isaacperez.runsbyip",
      profile_name: "match AppStore com.isaacperez.runsbyip",
      build_configurations: ["Release"],
      targets: ["RunsByIP"]
    )

    build_app(
      scheme: "RunsByIP",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "K98N9692X9",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.isaacperez.runsbyip" => "match AppStore com.isaacperez.runsbyip"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )

    puts "✅ Uploaded to TestFlight!"
  end

  desc "Sync signing certs and profiles from the shared certs repo (read-only)"
  lane :sync_signing do
    match(type: "appstore", app_identifier: "com.isaacperez.runsbyip", readonly: true)
  end

  desc "Generate or rotate signing certs and profiles in the shared certs repo"
  lane :rotate_signing do
    match(type: "appstore", app_identifier: "com.isaacperez.runsbyip", readonly: false)
  end

end
